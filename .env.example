# Copie este arquivo para ".env" e preencha com as credenciais do SEU
# projeto Firebase (Console Firebase > Configurações do projeto > Geral
# > "Seus apps" > Configuração do SDK).
#
# Nunca cometa o arquivo ".env" real no Git — ele já está no .gitignore.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional — só necessária se a busca de livros começar a ser bloqueada
# por limite de requisições (Documento 12 — APIs de Livros). Sem essa
# chave, a Google Books API já funciona normalmente para uso pessoal.
# Para gerar: console.cloud.google.com -> APIs e Serviços -> Credenciais
# -> Criar credencial -> Chave de API -> ativar a "Books API".
VITE_GOOGLE_BOOKS_API_KEY=
