# ============================================================
# PulseNote — Configurações do Backend
# Copie este arquivo como .env e preencha os valores
# ============================================================

# Servidor
PORT=3001
FRONTEND_URL=http://localhost:3001

# JWT — TROQUE ESTA CHAVE EM PRODUÇÃO!
JWT_SECRET=pulsenote-super-secret-jwt-key-2024-troque-isso

# CORS — domínio do frontend em produção
ALLOWED_ORIGIN=http://localhost:3001

# ── Email SMTP (opcional em desenvolvimento) ──────────────────
# Em dev, os emails são simulados pelo Ethereal e o link aparece no terminal.
# Para produção, configure um servidor SMTP real:

# Gmail (use App Password, não a senha normal):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu@gmail.com
# SMTP_PASS=abcd efgh ijkl mnop
# SMTP_FROM=PulseNote <seu@gmail.com>

# Outlook / Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu@outlook.com
# SMTP_PASS=sua-senha-aqui
# SMTP_FROM=PulseNote <seu@outlook.com>

# SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxx
# SMTP_FROM=no-reply@seudominio.com
