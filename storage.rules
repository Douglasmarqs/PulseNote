rules_version = '2';

// ============================================================
// Regras de Segurança do Firebase Storage — PulseNote
// ============================================================
// Cada usuário só pode ler/escrever na própria pasta de avatars.
// Máximo de 5 MB por arquivo. Somente imagens.
//
// COMO APLICAR:
// Firebase Console → Storage → Regras → cole este conteúdo → Publicar
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    // Avatars de perfil: avatars/{userId}/profile
    match /avatars/{userId}/{fileName} {
      // Só o próprio usuário pode fazer upload/deletar
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Qualquer pessoa autenticada pode ver o avatar
      // (necessário para exibir a foto para outros usuários no futuro)
      allow read: if request.auth != null;
    }

    // Bloqueia tudo mais
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
